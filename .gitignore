# Environment variables (generated by `make create` from cli/templates/env.example)
.env
.env.*

# DDEV auto-generated overrides (from `make share` / `make funnel`)
/.ddev/config.tailscale.yaml
/.ddev/traefik/certs/
/.ddev/traefik/config/

# Craft CMS
/config/license.key

# Project config — TEMPORARY during active starter + plugin development.
# Project config is regenerated on every `make create` based on the user's
# plugin selections, and the LR plugins it depends on are still in flux
# (Canvas Studio, etc.). When the plugin APIs stabilise we'll revisit what
# a committed baseline should look like.
#
# If you fork this starter for a client project, REMOVE this line and start
# tracking your project config like any normal Craft site.
/config/project/

# Dependencies
/vendor/
/node_modules/
/cli/node_modules/
/cli/tmp/

# Build files
/web/dist/

# Web assets
/web/assets/*
/web/cpresources/*
/web/cache/*
/web/transforms/*

# Storage
/storage/*
!/storage/.gitkeep

# Development tools & logs
.cache
*.log
yarn-error.log
npm-debug.log
pnpm-debug.log

# IDE & Editor files
.DS_Store
.idea/
.project
.settings/
*.esproj
*.sublime-workspace
*.sublime-project
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Database dumps — ignore exports; keep .sql.gzip for intentional seed DBs
*.sql
*.sql.gz
!*.sql.gzip

# Claude Code
CLAUDE.md
.claude/

# Internal notes / task tracking (not shipped)
/.internal/

# Documentation & backups
/_backup/
TODO.md
