# -----------------------------------------------------------------------------
# Craft CMS Starter — environment template
#
# This file is the source template used by `make create` to generate the
# project's .env. Anything here is reference-only — the LindemannRock CLI
# strips this header block when writing .env to the project root.
# -----------------------------------------------------------------------------

# Craft CMS Core
CRAFT_APP_ID=
CRAFT_SECURITY_KEY=
CRAFT_ENVIRONMENT=dev

# Admin & Development (auto-read by Craft via CRAFT_* env vars)
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_ALLOW_UPDATES=true
CRAFT_DISALLOW_ROBOTS=true
CRAFT_TIMEZONE=UTC
CRAFT_CP_TRIGGER=cms
CRAFT_TEMP_ASSET_UPLOAD_FS=temp
CRAFT_WEB_ROOT=/var/www/html/web

# System Settings
SYSTEM_NAME=""
SYSTEM_STATUS=On

# System Email
SYSTEM_EMAIL=
SYSTEM_EMAIL_REPLY_TO=
SYSTEM_SENDER_NAME=""

# Database
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=db
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=db
CRAFT_DB_USER=db
CRAFT_DB_PASSWORD=db
CRAFT_DB_SCHEMA=
CRAFT_DB_TABLE_PREFIX=

# Redis Cache (only used when Redis is selected during setup)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Site URLs
PRIMARY_SITE_URL=

# English Site
PRIMARY_SITE_URL_EN=
PRIMARY_SITE_NAME_EN=""
PRIMARY_SITE_LABEL_EN=En

# Arabic Site (removed if bilingual is disabled)
PRIMARY_SITE_URL_AR=
PRIMARY_SITE_NAME_AR=""
PRIMARY_SITE_LABEL_AR=Ar

# Translation Categories
TRANSLATION_CATEGORY_PRIMARY=site
TRANSLATION_CATEGORY_FORM=formie

# Vite Development Server
VITE_DEV_SERVER_PUBLIC=
VITE_DEV_SERVER_INTERNAL=http://localhost:3000/

# Email - Postmark
POSTMARK_TOKEN=

# Email - SMTP (Servd SMTP, Mailgun, etc.)
SMTP_HOSTNAME=
SMTP_PORT=
SMTP_USE_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=

# Email - Mailpit (local dev — DDEV's built-in mailcatcher)
MAILPIT_SMTP_HOSTNAME=127.0.0.1
MAILPIT_SMTP_PORT=1025

# Testing
CRAFT_TEST_TO_EMAIL_ADDRESS=

# SEO & Analytics
GA_TRACKING_ID=

# Servd Asset Storage (only used when Servd hosting is selected)
SERVD_PROJECT_SLUG=
SERVD_SECURITY_KEY=
SERVD_ASSETS_ENVIRONMENT=local

# Cloudflare (optional — fill in if using Cloudflare)
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ZONE_ID=

# Cloudflare Turnstile (optional — for bot protection)
CLOUDFLARE_TURNSTILE_SECRET_KEY=
CLOUDFLARE_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# LindemannRock plugin salts (auto-generated per install)
# -----------------------------------------------------------------------------
