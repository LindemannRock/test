# -----------------------------------------------------------------------------
# Craft CMS Starter — environment template
#
# This file is the source template used by `make create` to generate the
# project's .env. Anything here is reference-only — the LindemannRock CLI
# strips this header block when writing .env to the project root.
# -----------------------------------------------------------------------------

# Craft CMS Core
CRAFT_APP_ID=
CRAFT_SECURITY_KEY=
CRAFT_ENVIRONMENT=dev

# Admin & Development (auto-read by Craft via CRAFT_* env vars)
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_ALLOW_UPDATES=true
CRAFT_DISALLOW_ROBOTS=true
CRAFT_TIMEZONE=UTC
CRAFT_CP_TRIGGER=cms
CRAFT_IS_SYSTEM_LIVE=true
CRAFT_RUN_QUEUE_AUTOMATICALLY=true
CRAFT_TEMP_ASSET_UPLOAD_FS=temp

# System Settings
SYSTEM_NAME=""

# System Email
SYSTEM_EMAIL=
SYSTEM_EMAIL_REPLY_TO=
SYSTEM_SENDER_NAME=""

# Database
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=db
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=db
CRAFT_DB_USER=db
CRAFT_DB_PASSWORD=db
CRAFT_DB_SCHEMA=
CRAFT_DB_TABLE_PREFIX=

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Site URLs
PRIMARY_SITE_URL=

# English Site
PRIMARY_SITE_URL_EN=
PRIMARY_SITE_NAME_EN=""
PRIMARY_SITE_LABEL_EN=En

# Vite Development Server
VITE_DEV_SERVER_PUBLIC=
VITE_DEV_SERVER_INTERNAL=http://localhost:3000/

# Email - Postmark
POSTMARK_TOKEN=

# Email - SMTP (Servd SMTP, Mailgun, etc.)
SMTP_HOSTNAME=
SMTP_PORT=
SMTP_USE_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=

# Email - Mailpit (local dev — DDEV's built-in mailcatcher)
MAILPIT_SMTP_HOSTNAME=127.0.0.1
MAILPIT_SMTP_PORT=1025

# Testing
CRAFT_TEST_TO_EMAIL_ADDRESS=

# Servd Asset Storage
SERVD_PROJECT_SLUG=
SERVD_SECURITY_KEY=
SERVD_BASE_URL=
SERVD_ASSETS_ENVIRONMENT=local
SERVD_CDN_URL_PATTERN=
SERVD_IMAGE_TRANSFORM_URL_PATTERN=

# Campaign Manager (LR)
CAMPAIGN_MANAGER_BITLY_API_KEY=

# Redirect Manager (LR)
REDIRECT_MANAGER_IP_SALT=""
REDIRECT_MANAGER_DEFAULT_COUNTRY=AE
REDIRECT_MANAGER_DEFAULT_CITY=Dubai

# Search Manager (LR)
SEARCH_MANAGER_IP_SALT=""
SEARCH_MANAGER_DEFAULT_COUNTRY=AE
SEARCH_MANAGER_DEFAULT_CITY=Dubai

# Shortlink Manager (LR)
SHORTLINK_MANAGER_IP_SALT=""
SHORTLINK_MANAGER_DEFAULT_COUNTRY=AE
SHORTLINK_MANAGER_DEFAULT_CITY=Dubai

# Smartlink Manager (LR)
SMARTLINK_MANAGER_IP_SALT=""
SMARTLINK_MANAGER_DEFAULT_COUNTRY=AE
SMARTLINK_MANAGER_DEFAULT_CITY=Dubai

# Translation Manager (LR)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# Cloudflare
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ZONE_ID=

# Cloudflare Turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
