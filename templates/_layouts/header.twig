{# -- Site Header -- #}
<header
	class="sticky top-0 z-50 border-b border-gray-200 bg-white"
	x-data="{ mobileOpen: false }"
	x-show="!$store.session.hideHeader"
>
	<div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
		{# Logo #}
		<a href="{{ siteUrl }}" class="flex items-center" aria-label="{{ siteName }}">
			<span class="text-xl font-bold text-brand">{{ siteName }}</span>
		</a>

		{# Desktop Navigation #}
		<nav class="hidden items-center gap-6 md:flex" aria-label="{{ 'Main navigation'|t(primaryTranslationCategory) }}">
			{% for node in _globals.nav.main %}
				<a
					href="{{ node.url }}"
					class="text-sm font-medium text-gray-700 transition hover:text-brand"
					{% if node.newWindow %}target="_blank" rel="noopener"{% endif %}
				>
					{{ node.title }}
				</a>
			{% endfor %}

			{# Language Switcher #}
			{% if otherSites|length == 1 %}
				{# 2 sites: simple toggle button #}
				{% set other = otherSites|first %}
				{% set otherUrl = entry is defined ? (entry.getUrl(other.id) ?? other.baseUrl) : other.baseUrl %}
				<a
					href="{{ otherUrl }}"
					class="rounded-sm border border-gray-300 px-2 py-1 text-xs font-medium transition hover:bg-gray-100"
					hreflang="{{ other.language[:2] }}"
				>
					{{ getenv('PRIMARY_SITE_LABEL_' ~ other.handle|upper) ?: other.language[:2]|upper }}
				</a>
			{% elseif otherSites|length > 1 %}
				{# 3+ sites: dropdown #}
				<div x-data="{ open: false }" class="relative">
					<button
						@click="open = !open"
						class="rounded-sm border border-gray-300 px-2 py-1 text-xs font-medium transition hover:bg-gray-100"
					>
						{{ getenv('PRIMARY_SITE_LABEL_' ~ siteHandle|upper) ?: siteLang[:2]|upper }}
					</button>
					<div
						x-show="open"
						@click.outside="open = false"
						class="absolute end-0 mt-1 min-w-[6rem] rounded border border-gray-200 bg-white py-1 shadow-lg"
					>
						{% for site in allSites %}
							{% set url = entry is defined ? (entry.getUrl(site.id) ?? site.baseUrl) : site.baseUrl %}
							<a
								href="{{ url }}"
								hreflang="{{ site.language[:2] }}"
								class="block px-3 py-1 text-xs {{ site.id == currentSite.id ? 'font-bold text-brand' : 'text-gray-700 hover:bg-gray-100' }}"
							>
								{{ getenv('PRIMARY_SITE_LABEL_' ~ site.handle|upper) ?: site.name }}
							</a>
						{% endfor %}
					</div>
				</div>
			{% endif %}
		</nav>

		{# Mobile Menu Toggle #}
		<button
			class="md:hidden"
			@click="mobileOpen = !mobileOpen"
			aria-label="{{ 'Toggle menu'|t(primaryTranslationCategory) }}"
		>
			<svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path x-show="!mobileOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				<path x-show="mobileOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
			</svg>
		</button>
	</div>

	{# Mobile Navigation #}
	<div
		class="border-t border-gray-200 md:hidden"
		x-show="mobileOpen"
		x-collapse
		@click.outside="mobileOpen = false"
	>
		<nav class="space-y-1 px-4 py-3" aria-label="{{ 'Mobile navigation'|t(primaryTranslationCategory) }}">
			{% for node in _globals.nav.main %}
				<a
					href="{{ node.url }}"
					class="block rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100"
				>
					{{ node.title }}
				</a>
			{% endfor %}
		</nav>
	</div>
</header>
